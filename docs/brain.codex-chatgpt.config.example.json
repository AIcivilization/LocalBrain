{
  "defaultProvider": "codex-chatgpt-local",
  "defaultModel": "gpt-5.4-mini",
  "models": ["gpt-5.4-mini", "gpt-5.5"],
  "providers": {
    "codex-chatgpt-local": {
      "type": "codex-chatgpt-local",
      "displayName": "Codex ChatGPT Local Provider",
      "baseUrl": "https://chatgpt.com/backend-api/codex/responses",
      "localOnly": false,
      "experimental": true,
      "options": {
        "authPath": "/Users/wf/.codex/auth.json",
        "cliPath": "/opt/homebrew/bin/codex",
        "clientId": "app_EMoamEEZ73f0CkXaXp7hrann",
        "userAgent": "brain-local-codex-provider/0.1",
        "modelCacheTtlMs": 60000
      }
    },
    "opencode-local": {
      "type": "opencode-local",
      "displayName": "OpenCode Local Provider",
      "baseUrl": "http://127.0.0.1:4096",
      "localOnly": true,
      "experimental": true,
      "options": {
        "cliPath": "/Users/wf/.opencode/bin/opencode",
        "modelProvider": "opencode"
      }
    },
    "antigravity-local": {
      "type": "antigravity-local",
      "displayName": "Antigravity Local Provider",
      "localOnly": false,
      "experimental": true,
      "options": {
        "stateDbPath": "/Users/wf/Library/Application Support/Antigravity/User/globalStorage/state.vscdb",
        "sqlitePath": "sqlite3",
        "imageOutputDir": "/Users/wf/LocalBrain/logs/antigravity-images",
        "workspaceUri": "file:///Users/wf/LocalBrain",
        "modelCacheTtlMs": 60000
      }
    }
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "requireAuth": true,
    "apiKeys": ["local-brain-dev-key"],
    "publicBaseUrl": "http://127.0.0.1:8787",
    "auditLogPath": "logs/brain-server-audit.jsonl"
  },
  "routing": {
    "chat": {
      "providerId": "codex-chatgpt-local",
      "model": "gpt-5.4-mini"
    },
    "fast": {
      "providerId": "codex-chatgpt-local",
      "model": "gpt-5.4-mini"
    },
    "code": {
      "providerId": "codex-chatgpt-local",
      "model": "gpt-5.5"
    },
    "tool-use": {
      "providerId": "codex-chatgpt-local",
      "model": "gpt-5.5"
    }
  },
  "tools": {
    "enabled": false,
    "allowlist": [],
    "maxToolCalls": 0
  },
  "memory": {
    "mode": "session",
    "maxSessionMessages": 20
  },
  "policy": {
    "allowNetworkModelCalls": true,
    "allowExperimentalSubscriptionLogin": true,
    "allowProductStateInPrompt": true,
    "requireToolAllowlist": true
  }
